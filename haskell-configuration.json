{
    "comments": {
        "lineComment": "--",
        "blockComment": ["{-", "-}"]
    },
    "brackets": [
       ["{", "}"],
       ["[", "]"],
       ["(", ")"]
   ],
   "autoClosingPairs": [
       { "open": "{", "close": "}" },
       { "open": "[", "close": "]" },
       { "open": "(", "close": ")" },
       { "open": "\"", "close": "\"", "notIn": ["string"] },
       { "open": "`", "close": "`", "notIn": ["string", "comment"] }
   ],
   "surroundingPairs": [
       ["{", "}"],
       ["[", "]"],
       ["(", ")"],
       ["'", "'"],
       ["\"", "\""],
       ["`", "`"]
   ],
   "folding": {
       "offSide": true
   },
   "wordPattern": "/(?:[\\p{L}_][\\p{L}\\p{Nd}_']*#*)|(?:[\\p{S}\\p{P}](?<![(),;\\[\\]`{}_\"']))+/u"
}
